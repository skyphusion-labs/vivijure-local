{
  "name": "keyframe",
  "version": "0.2.1",
  "api": "vivijure-module/2",
  "hooks": [
    "keyframe"
  ],
  "provides": [
    {
      "id": "gpu-keyframe",
      "label": "GPU Keyframe (SDXL on RunPod)"
    }
  ],
  "config_schema": {
    "quality_tier": {
      "type": "enum",
      "values": [
        "draft",
        "standard",
        "final"
      ],
      "default": "final",
      "label": "quality tier"
    },
    "width": {
      "type": "int",
      "default": 1344,
      "min": 512,
      "max": 1536,
      "label": "width"
    },
    "height": {
      "type": "int",
      "default": 768,
      "min": 512,
      "max": 1536,
      "label": "height"
    },
    "steps": {
      "type": "int",
      "default": 30,
      "min": 1,
      "max": 60,
      "label": "diffusion steps"
    },
    "guidance_scale": {
      "type": "float",
      "default": 6.5,
      "min": 0,
      "max": 20,
      "label": "guidance scale"
    },
    "seed": {
      "type": "int",
      "default": -1,
      "min": -1,
      "label": "seed (-1 = random)"
    }
  },
  "ui": {
    "section": "keyframe",
    "order": 10
  },
  "cancelable": true,
  "keyframe_label": "SDXL"
}
