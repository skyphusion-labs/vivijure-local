{
  "name": "kling",
  "version": "0.1.1",
  "api": "vivijure-module/2",
  "hooks": [
    "motion.backend"
  ],
  "provides": [
    {
      "id": "i2v-cloud",
      "label": "Kling V2.1 Pro (cloud i2v)"
    }
  ],
  "config_schema": {
    "guidance_scale": {
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "label": "guidance scale"
    },
    "negative_prompt": {
      "type": "string",
      "default": "",
      "label": "negative prompt"
    },
    "enable_safety_checker": {
      "type": "bool",
      "default": true,
      "label": "safety checker"
    }
  },
  "ui": {
    "section": "motion",
    "order": 20,
    "locality": "cloud",
    "cost": "Pay per render",
    "blurb": "Rents datacenter GPUs by the second -- top quality, scale-to-zero; you pay only for render seconds."
  }
}
