{
  "name": "own-gpu",
  "version": "0.1.1",
  "api": "vivijure-module/2",
  "hooks": [
    "motion.backend"
  ],
  "provides": [
    {
      "id": "i2v-own-gpu",
      "label": "Own GPU (Wan2.2 i2v)"
    }
  ],
  "config_schema": {
    "quality": {
      "type": "enum",
      "values": [
        "draft",
        "standard",
        "final"
      ],
      "default": "standard",
      "label": "quality"
    },
    "fps": {
      "type": "int",
      "default": 16,
      "min": 8,
      "max": 30,
      "label": "fps"
    },
    "flow_shift": {
      "type": "float",
      "default": 5,
      "min": 1,
      "max": 12,
      "label": "motion (flow shift, lower = faster)"
    },
    "negative_prompt": {
      "type": "string",
      "default": "",
      "label": "negative prompt (additive)"
    },
    "seed": {
      "type": "int",
      "default": -1,
      "min": -1,
      "label": "seed (-1 = random)"
    }
  },
  "ui": {
    "section": "motion",
    "order": 5,
    "locality": "byo",
    "cost": "Own keys (your RunPod endpoint)",
    "blurb": "Renders on your own RunPod GPU endpoint -- own keys, no per-render markup; quality follows the GPU tier you rent."
  }
}
