{
  "name": "finish-upscale",
  "version": "0.1.3",
  "api": "vivijure-module/2",
  "hooks": [
    "finish"
  ],
  "provides": [
    {
      "id": "upscale",
      "label": "Upscale resolution (Real-ESRGAN)"
    }
  ],
  "config_schema": {
    "scale": {
      "type": "int",
      "default": 2,
      "min": 2,
      "max": 4,
      "label": "upscale factor",
      "enum_labels": {
        "2": "2x",
        "4": "4x"
      }
    },
    "model": {
      "type": "enum",
      "values": [
        "realesr-animevideov3",
        "RealESRGAN_x4plus"
      ],
      "default": "realesr-animevideov3",
      "label": "model"
    }
  },
  "ui": {
    "section": "finish",
    "icon": "expand",
    "order": 20
  },
  "finish_artifacts": {
    "output_key": {
      "kind": "append_suffix",
      "suffix": "_up"
    },
    "applied": [
      {
        "tag": "upscale:{scale|2}x"
      }
    ]
  }
}
