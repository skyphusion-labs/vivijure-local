{
  "name": "google-veo",
  "version": "0.1.1",
  "api": "vivijure-module/2",
  "hooks": [
    "motion.backend"
  ],
  "provides": [
    {
      "id": "i2v-cloud",
      "label": "Google Veo 3.1 Fast (cloud i2v)"
    }
  ],
  "config_schema": {
    "generate_audio": {
      "type": "bool",
      "default": false,
      "label": "native audio (off: core mux chain owns audio)"
    }
  },
  "ui": {
    "section": "motion",
    "order": 50,
    "locality": "cloud",
    "cost": "Pay per render",
    "blurb": "Rents datacenter GPUs by the second -- top quality, scale-to-zero; you pay only for render seconds."
  }
}
