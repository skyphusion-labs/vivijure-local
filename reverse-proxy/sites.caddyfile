# Default sites (Cloudflare DNS-01 for MinIO wildcard).
# `npm run install:edge` writes sites.runtime.caddyfile for other providers;
# compose mounts that file over this one when present.
{$CADDY_APP_HOST} {
	reverse_proxy studio:8790
}

{$CADDY_MINIO_HOST}, *.{$CADDY_MINIO_HOST} {
	tls {
		dns cloudflare {env.CF_DNS_TOKEN}
	}
	reverse_proxy minio:9000
}
