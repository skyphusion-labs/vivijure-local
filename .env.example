# Studio
PORT=8790
PUBLIC_BASE_URL=http://127.0.0.1:8790
AUTH_MODE=token
STUDIO_API_TOKEN=change-me-local-dev-only

# SQLite (local metadata)
DATABASE_PATH=./data/studio.db

# --- Object storage (S3-compatible; default = local MinIO) ---
# Same variable names work for MinIO, AWS S3, or Cloudflare R2 -- only endpoint/region change.
S3_ENDPOINT=http://127.0.0.1:9000
# When studio runs in Docker but presigned URLs are fetched from host/GPU, use a reachable host:
# S3_PRESIGN_ENDPOINT=http://host.docker.internal:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=vivijure
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Optional second bucket for chat-side artifacts (defaults to S3_BUCKET)
# S3_CHAT_BUCKET=skyphusion-llm

# --- Cloudflare R2 example (swap in when ready) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=vivijure
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# Filesystem fallback (only used when S3_* is unset; CI/tests)
# ARTIFACT_ROOT=./data/artifacts

# Planner: set true for offline dev without provider keys
PLANNER_AI_MOCK=false

# BYOK (optional; direct provider APIs, no Workers AI)
# XAI_API_KEY=
# OPENAI_API_KEY=

# --- Module sidecars (HTTP transport) ---
# MODULE_KEYFRAME_URL=http://127.0.0.1:9101
# MODULE_LOCAL_GPU_URL=http://127.0.0.1:9102

# CPU media stack (vivijure/containers parity)
VIDEO_FINISH_URL=http://127.0.0.1:8780
IMAGE_PREP_URL=http://127.0.0.1:8781
AUDIO_BEAT_SYNC_URL=http://127.0.0.1:8782
AUDIO_MIX_URL=http://127.0.0.1:8783
AUDIO_MASTER_URL=http://127.0.0.1:8784
