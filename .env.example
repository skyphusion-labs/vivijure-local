# Studio
PORT=8790
PUBLIC_BASE_URL=http://127.0.0.1:8790
AUTH_MODE=token
STUDIO_API_TOKEN=change-me-local-dev-only

# SQLite + artifacts (created on first boot)
DATABASE_PATH=./data/studio.db
ARTIFACT_ROOT=./data/artifacts

# Planner: set true for offline dev without provider keys
PLANNER_AI_MOCK=false

# BYOK (optional; direct provider APIs, no Workers AI)
# XAI_API_KEY=
# OPENAI_API_KEY=

# --- Module sidecars (HTTP transport) ---
# Each bound module needs MODULE_<NAME>_URL. Unset = module absent from registry.
# MODULE_KEYFRAME_URL=http://127.0.0.1:9101
# MODULE_LOCAL_GPU_URL=http://127.0.0.1:9102
# MODULE_FINISH_RIFE_URL=http://127.0.0.1:9110
# MODULE_BEAT_SYNC_URL=http://127.0.0.1:9120
# MODULE_AUDIO_MASTER_URL=http://127.0.0.1:9121

# local-gpu module -> your homelab GPU backend
# LOCAL_BACKEND_URL=http://127.0.0.1:8888
# LOCAL_BACKEND_TOKEN=

# RunPod (optional cloud profile; own-gpu module + cast LoRA train)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# CPU media stack (vivijure/containers parity)
VIDEO_FINISH_URL=http://127.0.0.1:8780
IMAGE_PREP_URL=http://127.0.0.1:8781
AUDIO_BEAT_SYNC_URL=http://127.0.0.1:8782
AUDIO_MIX_URL=http://127.0.0.1:8783
AUDIO_MASTER_URL=http://127.0.0.1:8784

# MinIO (optional; replaces ARTIFACT_ROOT for S3-compat presign)
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=vivijure
