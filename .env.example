# Studio
PORT=8790
PUBLIC_BASE_URL=http://127.0.0.1:8790
AUTH_MODE=token
STUDIO_API_TOKEN=change-me-local-dev-only

# Compose images (default: GHCR :latest; `npm run compose:up` pulls before up).
# :latest moves ONLY when a SemVer release tag (vX.Y.Z) is cut -- a merge to main
# no longer republishes it. Pin a release with VJ_IMAGE_TAG=1.2.0 (no v prefix).
# Packages are public; no docker login needed to pull.
# VJ_IMAGE_REGISTRY=ghcr.io/skyphusion-labs
# VJ_IMAGE_TAG=latest
# VJ_IMAGE_TAG=1.2.0

# SQLite (local metadata)
DATABASE_PATH=./data/studio.db

# --- Object storage (S3-compatible; default = local MinIO) ---
# Same variable names work for MinIO, AWS S3, or Cloudflare R2 -- only endpoint/region change.
S3_ENDPOINT=http://127.0.0.1:9000
# Host embedded in presigned URLs. In compose, defaults to http://minio:9000 (in-network).
# For RunPod / remote GPU backends, expose MinIO with COMPOSE_PROFILES=edge and set HTTPS here:
# S3_PRESIGN_ENDPOINT=https://s3.example.com
# S3_FETCH_ALLOW_HOSTS=minio,s3.example.com
# S3_ALLOW_HTTP_FETCH=false
# See docs/EDGE.md (npm run install:edge fills these)
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=vivijure
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Optional second bucket for chat-side artifacts (defaults to S3_BUCKET)
# S3_CHAT_BUCKET -- RETIRED (vivijure-cf#140). Chat image artifacts are stored in S3_BUCKET so
# that GET /api/artifact can serve them; a separate chat bucket meant every preview 404'd. If it is
# still set, the studio logs a warning at startup and ignores it.

# --- Cloudflare R2 example (swap in when ready) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=vivijure
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# Filesystem fallback (only used when S3_* is unset; CI/tests)
# ARTIFACT_ROOT=./data/artifacts

# Optional demo studio (AUTH_MODE=demo) -- keep off for homelab operator installs
# AUTH_MODE=token
# DEMO_RENDER_ENABLED=false
# DEMO_ARTIFACT_ORIGIN=http://127.0.0.1:8790/api/artifact
# DEMO_RENDER_PER_IP_DAILY=3
# DEMO_CHAT_PER_IP_DAILY=20
# After base migrate: npm run migrate:demo

# Planner: set true for offline dev without provider keys (default in docker compose)
PLANNER_AI_MOCK=false

# --- Cloudflare AI Gateway / Unified Billing (same vars as vivijure Worker) ---
# CLOUDFLARE_ACCOUNT_ID=
# GATEWAY_ID=vivijure
# CF_AIG_TOKEN=

# Direct BYOK fallback when gateway vars are unset
# ANTHROPIC_API_KEY=

# plan.enhance module only: override cloud model (default claude-opus-4-8). Without gateway creds the
# module falls back to Workers AI local llama; swap MODULE_PLANENHANCE_URL to a different module to
# change the whole planning-AI stack.
# ENHANCE_MODEL=claude-opus-4-8

# RunPod (when binding cloud / own-gpu / keyframe modules; same names as upstream Secrets Store)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=          # default when per-module overrides unset
# BACKEND_RUNPOD_ENDPOINT_ID=    # Wan i2v / own-gpu / finish-rife (vivijure-backend)
# KEYFRAME_RUNPOD_ENDPOINT_ID= # SDXL keyframe when split from the i2v backend
# VIDEO_UPSCALE_RUNPOD_ENDPOINT_ID=
# MUSETALK_RUNPOD_ENDPOINT_ID=
# AUDIO_UPSCALE_RUNPOD_ENDPOINT_ID=

# Homelab GPU backend (local-gpu module proxies here; localhost, VLAN, or public HTTPS URL)
# LOCAL_BACKEND_URL=https://gpu.example.com
# LOCAL_BACKEND_TOKEN=

# --- Module sidecars (HTTP transport; compose wires 25 by default) ---
# MODULE_KEYFRAME_URL=http://127.0.0.1:9101
# MODULE_LOCAL_GPU_URL=http://127.0.0.1:9102
# MODULE_OWN_GPU_URL=http://127.0.0.1:9103
# MODULE_FINISH_RIFE_URL=http://127.0.0.1:9110
# MODULE_LIPSYNC_URL=http://127.0.0.1:9111
# MODULE_UPSCALE_URL=http://127.0.0.1:9112
# MODULE_SEEDANCE_URL=http://127.0.0.1:9150
# MODULE_KLING_URL=http://127.0.0.1:9151
# MODULE_GOOGLE_VEO_URL=http://127.0.0.1:9152
# MODULE_MINIMAX_HAILUO_URL=http://127.0.0.1:9153
# MODULE_VIDU_Q3_URL=http://127.0.0.1:9154
# MODULE_ALIBABA_WAN_URL=http://127.0.0.1:9155
# MODULE_ALIBABA_WAN_LORA_URL=http://127.0.0.1:9156  # opt-in: COMPOSE_PROFILES=wan-lora
# MODULE_CLOUD_KEYFRAME_URL=http://127.0.0.1:9157
# MODULE_MUSIC_GEN_URL=http://127.0.0.1:9158
# MODULE_NARRATION_GEN_URL=http://127.0.0.1:9159

# MODULE_BEAT_SYNC_URL=http://127.0.0.1:9120
# MODULE_AUDIO_MASTER_URL=http://127.0.0.1:9121
# MODULE_FILM_TITLES_URL=http://127.0.0.1:9130
# MODULE_SUBTITLE_URL=http://127.0.0.1:9131
# MODULE_PLANENHANCE_URL=http://127.0.0.1:9140
# MODULE_CAST_IMAGE_URL=http://127.0.0.1:9141
# MODULE_DIALOGUE_URL=http://127.0.0.1:9142
# MODULE_SPEECH_UPSCALE_URL=http://127.0.0.1:9143
# MODULE_NOTIFY_EMAIL_URL=http://127.0.0.1:9144

# CPU media stack (vivijure/containers parity)
VIDEO_FINISH_URL=http://127.0.0.1:8780
IMAGE_PREP_URL=http://127.0.0.1:8781
AUDIO_BEAT_SYNC_URL=http://127.0.0.1:8782
AUDIO_MIX_URL=http://127.0.0.1:8783
AUDIO_MASTER_URL=http://127.0.0.1:8784

# --- Public HTTPS edge (COMPOSE_PROFILES=edge; npm run install:edge; see docs/EDGE.md) ---
# EDGE_PUBLIC_IP=                     # A/AAAA target (WAN IP or load-balancer VIP)
# EDGE_BIND_IP=0.0.0.0                # host bind for :80/:443 (VLAN IP if behind L4 LB)
# CADDY_APP_HOST=studio.example.com
# CADDY_MINIO_HOST=s3.example.com     # wildcard *.s3.example.com covered for bucket vhosts
# CADDY_ACME_EMAIL=you@example.com
# CADDY_DNS_PROVIDER=cloudflare       # or route53, digitalocean, googleclouddns, hetzner, ovh
# CADDY_TLS_MODE=dns                  # or files (mount reverse-proxy/certs/)
# CF_DNS_TOKEN=                       # if provider=cloudflare (Zone DNS Edit)
# AWS_ACCESS_KEY_ID=                  # if provider=route53
# AWS_SECRET_ACCESS_KEY=
# AWS_HOSTED_ZONE_ID=
# DO_AUTH_TOKEN=                      # if provider=digitalocean
# GCP_PROJECT=                        # if provider=googleclouddns
# GOOGLE_APPLICATION_CREDENTIALS=
# HETZNER_API_TOKEN=                  # if provider=hetzner
# OVH_ENDPOINT=                       # if provider=ovh
# OVH_APPLICATION_KEY=
# OVH_APPLICATION_SECRET=
# OVH_CONSUMER_KEY=
# CADDY_PROXY_ALLOW=                  # only if L4 LB sends PROXY protocol: LB source CIDR
# MINIO_PUBLIC_DOMAIN=s3.example.com  # same as CADDY_MINIO_HOST (MinIO virtual-host routing)
