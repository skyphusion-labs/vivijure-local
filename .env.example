# Studio
PORT=8790
PUBLIC_BASE_URL=http://127.0.0.1:8790
AUTH_MODE=token
STUDIO_API_TOKEN=change-me-local-dev-only

# SQLite (local metadata)
DATABASE_PATH=./data/studio.db

# --- Object storage (S3-compatible; default = local MinIO) ---
# Same variable names work for MinIO, AWS S3, or Cloudflare R2 -- only endpoint/region change.
S3_ENDPOINT=http://127.0.0.1:9000
# When studio runs in Docker but presigned URLs are fetched from host/GPU, use a reachable host:
# S3_PRESIGN_ENDPOINT=http://host.docker.internal:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=vivijure
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Optional second bucket for chat-side artifacts (defaults to S3_BUCKET)
# S3_CHAT_BUCKET=skyphusion-llm

# --- Cloudflare R2 example (swap in when ready) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=vivijure
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# Filesystem fallback (only used when S3_* is unset; CI/tests)
# ARTIFACT_ROOT=./data/artifacts

# Optional demo studio (AUTH_MODE=demo)
# AUTH_MODE=demo
# DEMO_RENDER_ENABLED=true
# DEMO_ARTIFACT_ORIGIN=http://127.0.0.1:8790/api/artifact
# DEMO_RENDER_PER_IP_DAILY=3
# DEMO_CHAT_PER_IP_DAILY=20
# After base migrate: npm run migrate:demo

# Planner: set true for offline dev without provider keys (default in docker compose)
PLANNER_AI_MOCK=false

# --- Cloudflare AI Gateway / Unified Billing (same vars as vivijure Worker) ---
# CLOUDFLARE_ACCOUNT_ID=
# GATEWAY_ID=vivijure
# CF_AIG_TOKEN=

# Direct BYOK fallback when gateway vars are unset
# ANTHROPIC_API_KEY=

# plan.enhance module only: override cloud model (default claude-opus-4-8). Without gateway creds the
# module falls back to Workers AI local llama; swap MODULE_PLANENHANCE_URL to a different module to
# change the whole planning-AI stack.
# ENHANCE_MODEL=claude-opus-4-8

# RunPod (when binding cloud / own-gpu modules; same names as upstream Secrets Store)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# --- Module sidecars (HTTP transport) ---
# MODULE_KEYFRAME_URL=http://127.0.0.1:9101
# MODULE_LOCAL_GPU_URL=http://127.0.0.1:9102

# Optional finish GPU satellites (docker compose --profile satellites)
# MODULE_FINISH_RIFE_URL=http://127.0.0.1:9110
# MODULE_FINISH_LIPSYNC_URL=http://127.0.0.1:9111

# Optional cloud / RunPod module sidecars (install profile; see docs/install-profiles.md)
# MODULE_CLOUD_KEYFRAME_URL=https://module-keyframe.example.workers.dev
# MODULE_OWN_GPU_URL=https://module-local-gpu.example.workers.dev
# MODULE_RUNPOD_I2V_URL=https://module-runpod-i2v.example.workers.dev

# MODULE_BEAT_SYNC_URL=http://127.0.0.1:9120
# MODULE_AUDIO_MASTER_URL=http://127.0.0.1:9121
# MODULE_FILM_TITLES_URL=http://127.0.0.1:9130
# MODULE_SUBTITLE_URL=http://127.0.0.1:9131
# MODULE_PLANENHANCE_URL=http://127.0.0.1:9140
# MODULE_CAST_IMAGE_URL=http://127.0.0.1:9141
# MODULE_DIALOGUE_URL=http://127.0.0.1:9142
# MODULE_SPEECH_UPSCALE_URL=http://127.0.0.1:9143
# MODULE_NOTIFY_EMAIL_URL=http://127.0.0.1:9144

# CPU media stack (vivijure/containers parity)
VIDEO_FINISH_URL=http://127.0.0.1:8780
IMAGE_PREP_URL=http://127.0.0.1:8781
AUDIO_BEAT_SYNC_URL=http://127.0.0.1:8782
AUDIO_MIX_URL=http://127.0.0.1:8783
AUDIO_MASTER_URL=http://127.0.0.1:8784
